{
  "name": "vidya",
  "version": "0.1.0",
  "main": "index.js",
  "private": true,
  "description": "Vid (Vidya) — Socratic AI Tutor",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "start": "node apps/api/dist/index.js",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "db:push": "pnpm --filter api db:push",
    "db:seed": "pnpm --filter api db:seed",
    "postinstall": "pnpm --filter @vidya/api exec prisma generate --schema=prisma/schema.prisma || true",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.3.0"
  },
  "packageManager": "pnpm@8.15.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "serve": "^14.2.6"
  }
}
