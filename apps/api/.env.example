# ============================================
# Vidya API - Environment Variables
# ============================================
#
# This file is safe-to-commit template values only.
# Store real secrets in `.env.local`.

# Database (PostgreSQL via Supabase)
# Local: postgresql://user@localhost:5432/vidya?schema=public
# Supabase (production): postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL="postgresql://user:password@localhost:5432/vidya?schema=public"

# LLM provider selection (default to SLM)
# Supported values: anthropic, openai, ollama, vllm
LLM_PROVIDER="ollama"
# Optional fallback provider if primary fails (e.g., provider down)
LLM_FALLBACK_PROVIDER="openai"

# Anthropic API
ANTHROPIC_API_KEY=""
ANTHROPIC_ANALYSIS_MODEL="claude-3-haiku-20240307"
ANTHROPIC_RESPONSE_MODEL="claude-3-haiku-20240307"

# OpenAI API
OPENAI_API_KEY=""
OPENAI_ANALYSIS_MODEL="gpt-4.1-nano"
OPENAI_RESPONSE_MODEL="gpt-4.1-nano"

# SLM providers (optional — for per-module SLM routing)
# Ollama (local dev)
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="llama3.2:3b"
# vLLM (hosted/staging)
VLLM_BASE_URL="http://localhost:8000"
VLLM_MODEL="meta-llama/Llama-3.2-3B-Instruct"

# Per-module model overrides (leave empty to use global defaults)
CODING_RESPONSE_PROVIDER=""
CODING_RESPONSE_MODEL=""
CODING_ANALYSIS_PROVIDER=""
CODING_ANALYSIS_MODEL=""
AI_LEARNING_RESPONSE_PROVIDER=""
AI_LEARNING_RESPONSE_MODEL=""
AI_LEARNING_ANALYSIS_PROVIDER=""
AI_LEARNING_ANALYSIS_MODEL=""

# LLM cost controls (optional)
# Approx tokens per char (default 4 if unset)
LLM_TOKEN_CHARS=4
# Hard caps (per process) - set to enable
LLM_MAX_TOKENS_PER_MINUTE=0
LLM_MAX_TOKENS_PER_DAY=0

# Provider health checks (optional)
LLM_HEALTH_TTL_MS=60000
LLM_HEALTH_TIMEOUT_MS=2000

# Redis (for caching, rate limiting, session summaries)
# Local: redis://localhost:6379
# Upstash (production): rediss://default:token@host.upstash.io:6379
REDIS_URL="redis://localhost:6379"

# Server
PORT=4000
NODE_ENV=development

# CORS - Comma-separated list of allowed origins
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:5173,https://mypathwiz.com"

# Admin API Secret (for managing API keys)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SECRET=""

# Stripe (for metered overage billing)
# Required to report overage usage to Stripe for STANDARD/PREMIUM keys
STRIPE_SECRET_KEY=""
# Billing Meter event name (create a Meter in Stripe Dashboard first)
STRIPE_METER_EVENT_NAME="vidya_api_overage"

# Sentry (for error monitoring)
# Create a project at sentry.io, then copy the DSN
SENTRY_DSN=""
