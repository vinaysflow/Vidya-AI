# ============================================
# Vidya API - Local Secrets Template
# ============================================
#
# Copy this file to `.env.local` and fill actual values:
#   cp .env.local.example .env.local
#
# `.env.local` should never be committed.

DATABASE_URL="postgresql://user:password@localhost:5432/vidya?schema=public"

# LLM provider routing (default to SLM)
# Supported: anthropic, openai, ollama, vllm
LLM_PROVIDER="ollama"
LLM_FALLBACK_PROVIDER="openai"

# Provider API keys
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""

# Cheapest defaults
OPENAI_ANALYSIS_MODEL="gpt-4.1-nano"
OPENAI_RESPONSE_MODEL="gpt-4.1-nano"
ANTHROPIC_ANALYSIS_MODEL="claude-3-haiku-20240307"
ANTHROPIC_RESPONSE_MODEL="claude-3-haiku-20240307"

# SLM providers (optional)
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="llama3.2:3b"
VLLM_BASE_URL="http://localhost:8000"
VLLM_MODEL="meta-llama/Llama-3.2-3B-Instruct"

# Per-module model overrides (leave empty to use global defaults)
# Example: route Coding responses to local Ollama
# CODING_RESPONSE_PROVIDER="ollama"
# CODING_RESPONSE_MODEL="llama3.2:3b"

# LLM cost controls (optional)
LLM_TOKEN_CHARS=4
LLM_MAX_TOKENS_PER_MINUTE=0
LLM_MAX_TOKENS_PER_DAY=0

# Provider health checks (optional)
LLM_HEALTH_TTL_MS=60000
LLM_HEALTH_TIMEOUT_MS=2000

REDIS_URL="redis://localhost:6379"
PORT=4000
NODE_ENV=development
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:5173"
ADMIN_SECRET=""

# Optional billing
STRIPE_SECRET_KEY=""
STRIPE_METER_EVENT_NAME="vidya_api_overage"

# Sentry (for error monitoring in production)
SENTRY_DSN=""
