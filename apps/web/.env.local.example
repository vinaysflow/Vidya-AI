# ============================================
# Vid Web - Local Environment
# ============================================
#
# Copy this file to `.env.local`:
#   cp .env.local.example .env.local
#
# `.env.local` is intended for machine-specific values and should not be committed.

VITE_API_URL=http://localhost:4000
VITE_ENABLE_VOICE_INPUT=false
VITE_ENABLE_IMAGE_INPUT=false
VITE_ENABLE_OFFLINE_MODE=true
VITE_FEATURE_FREEZE=false
