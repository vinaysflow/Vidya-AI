# ============================================
# Vid Web - Environment Variables
# ============================================
#
# This file is safe-to-commit template values only.
# Put machine-specific values in `.env.local`.

# API URL (in development, Vite proxies /api to this)
VITE_API_URL=http://localhost:4000

# Feature flags
VITE_ENABLE_VOICE_INPUT=false
VITE_ENABLE_IMAGE_INPUT=false
VITE_ENABLE_OFFLINE_MODE=true
VITE_FEATURE_FREEZE=false

# AI-generated scene images via /api/game/scene-image (uses DALL-E or similar)
# Set to "true" to enable; SVG scenes are the primary fallback when disabled
VITE_ENABLE_AI_SCENES=false

# Session recording — Microsoft Clarity (free, no data cap)
# 1. Sign up at https://clarity.microsoft.com
# 2. Create a project, copy the project ID
# 3. Set VITE_CLARITY_ID here to enable session recordings in production
# VITE_CLARITY_ID=your_clarity_project_id_here
