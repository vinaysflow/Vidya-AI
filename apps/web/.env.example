# ============================================
# Vid Web - Environment Variables
# ============================================
#
# This file is safe-to-commit template values only.
# Put machine-specific values in `.env.local`.

# API URL (in development, Vite proxies /api to this)
VITE_API_URL=http://localhost:4000

# Feature flags
VITE_ENABLE_VOICE_INPUT=false
VITE_ENABLE_IMAGE_INPUT=false
VITE_ENABLE_OFFLINE_MODE=true
VITE_FEATURE_FREEZE=false
